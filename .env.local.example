# PatientPartner Social Media Agent — environment variables.
# Copy to .env.local and fill in. Never commit .env.local.

# ─── Supabase ─────────────────────────────────────────
# Create a project at supabase.com → Project Settings → API.
# Create a public storage bucket named "post-assets" for image/PDF uploads.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Publer ───────────────────────────────────────────
# Requires Publer Business plan ($21/mo) for API access.
# PUBLER_WORKSPACE_ID: visible in Publer URL after sign-in.
# PUBLER_LINKEDIN_ACCOUNT_ID: fetch once via `GET /api/v1/social_accounts`.
PUBLER_API_KEY=
PUBLER_WORKSPACE_ID=
PUBLER_LINKEDIN_ACCOUNT_ID=

# ─── Anthropic (Claude) ───────────────────────────────
# Model: claude-opus-4-7 (hardcoded in lib/constants.ts).
ANTHROPIC_API_KEY=

# ─── Slack ────────────────────────────────────────────
# Incoming webhook URL. Used for "posts ready for review" + failure alerts.
SLACK_WEBHOOK_URL=

# ─── Vercel Cron ──────────────────────────────────────
# Any random string. Cron routes verify this header.
CRON_SECRET=

# ─── Generation cadence ───────────────────────────────
# Bi-monthly — comma-separated days of the month (1-28).
# Default "1,15". Swap to "3,17" or similar to shift the cadence.
GENERATION_RUN_DAYS=1,15
# Optional UI override for the cadence label ("bi-monthly", "1st and 15th", etc).
# CADENCE_LABEL="1st and 15th"

# ─── App ──────────────────────────────────────────────
# Used in Slack notifications as the base URL for dashboard links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Dev safety ───────────────────────────────────────
# Set to "true" in non-prod environments. Approve endpoint will log the Publer
# payload instead of actually scheduling. Unset in prod.
DEV_MODE=true
